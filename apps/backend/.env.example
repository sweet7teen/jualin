# ==========================================
# Application
# ==========================================
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
API_VERSION=v1

# ==========================================
# Database
# ==========================================
DATABASE_URL="mysql://root:root@localhost:3306/belidisini"

# ==========================================
# Redis
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==========================================
# Storage (MinIO / S3)
# ==========================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=belidisini
MINIO_USE_SSL=false

# ==========================================
# JWT Authentication (expiry in seconds)
# ==========================================
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# ==========================================
# Auth
# ==========================================
BCRYPT_ROUNDS=12

# ==========================================
# Swagger
# ==========================================
SWAGGER_TITLE=Belidisini API
SWAGGER_DESCRIPTION=Belidisini SaaS Marketplace API
SWAGGER_VERSION=0.1.0

# ==========================================
# CORS
# ==========================================
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ==========================================
# Pagination
# ==========================================
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100
